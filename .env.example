# SITE URL – viktigt för SEO (canonical, OG, sitemap). Sätt din domän vid build.
VITE_SITE_URL=https://example.com

# AdSense – fyll i när du fått godkänd
VITE_ADSENSE_CLIENT=ca-pub-1234567890123456
VITE_ADSENSE_SLOT_TOP=1234567890
VITE_ADSENSE_SLOT_MIDDLE=1234567891
VITE_ADSENSE_SLOT_BOTTOM=1234567892

# Feedback – välj ett alternativ:
# 1) E-post: formulär + mailto (FormSubmit.co skickar till denna adress)
VITE_CONTACT_EMAIL=feedback@example.com
# 2) GitHub: länk till "Rapportera på GitHub" (t.ex. användare/repo)
# VITE_GITHUB_REPO=användare/repo

# Samarbeten – e-post för affiliate-/partnersförfrågningar (fallback till VITE_CONTACT_EMAIL)
# VITE_PARTNERSHIP_EMAIL=partners@example.com

# Affiliate – fyll i när du har partnerskap (Avanza, Nordea, etc.)
VITE_AFFILIATE_ISK=https://
VITE_AFFILIATE_SPARKONTO=https://
VITE_AFFILIATE_PENSION=https://
